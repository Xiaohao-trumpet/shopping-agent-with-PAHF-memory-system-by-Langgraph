# Copy this file to .env and fill API_KEY for real AI replies.
MODEL_NAME=mimo-v2.5-pro
BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
API_KEY=

HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
LOG_FORMAT=text
CORS_ORIGINS=*

PAHF_BACKEND=sqlite
PAHF_SQLITE_DB_PATH=./data/pahf/pahf_memory.db
PAHF_FAISS_PATH=./data/pahf/pahf_memory
PAHF_TOP_K=5
PAHF_SIMILARITY_THRESHOLD=0.45
PAHF_EMBEDDING_MODE=hash
PAHF_ENABLE_PRE_CLARIFICATION=true
PAHF_ENABLE_POST_CORRECTION=true

TOOLS_ENABLED=true
TOOLS_ALLOWLIST=kb_search,create_ticket,get_ticket,list_tickets,product_search,get_product_detail,check_inventory,get_order,list_orders,track_shipment,recommend_products,list_coupons,apply_coupon,initiate_return
TOOL_MAX_CALLS_PER_TURN=3
TOOL_TIMEOUT_SECONDS=3.0
TOOL_RATE_LIMIT_PER_MINUTE=30

KB_FILE_PATH=./data/kb/faq.json
TICKET_DB_PATH=./data/tickets/tickets.db
CATALOG_DB_PATH=./data/catalog/catalog.db
CATALOG_AUTO_SEED=true
CONVERSATION_DB_PATH=./data/conversations/conversations.db
FEEDBACK_DB_PATH=./data/feedback/feedback.db
REVIEW_DB_PATH=./data/reviews/reviews.db
REVIEW_AUTO_SEED=true

# Backoffice admin login for local demo. Change the password before real use.
ADMIN_DB_PATH=./data/admin/admin.db
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=Admin@2026!
ADMIN_SESSION_TTL_SECONDS=86400

# Vite frontend. Local dev can omit this; production defaults to /server.
VITE_API_BASE_URL=/server
